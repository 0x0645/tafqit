{
  "name": "@0x0645/tafqit",
  "version": "1.0.0",
  "description": "TypeScript Arabic tafqit/tafqeet package with grammatical rules, currencies, and counted nouns.",
  "license": "MIT",
  "packageManager": "pnpm@9.11.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0x0645/tafqit.git"
  },
  "homepage": "https://github.com/0x0645/tafqit#readme",
  "bugs": {
    "url": "https://github.com/0x0645/tafqit/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:example": "pnpm --filter tafqit-example build",
    "check": "tsc --noEmit",
    "dev:example": "pnpm --filter tafqit-example dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run"
  },
  "keywords": [
    "arabic",
    "tafqit",
    "tafqeet",
    "number-to-words",
    "typescript"
  ],
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "tsup": "^8.5.0",
    "eslint": "^9.22.0",
    "globals": "^15.15.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.2.4"
  }
}
